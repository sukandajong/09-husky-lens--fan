C และตั้งโหมดจำแนกวัตถุ (Object Classification)\nhuskylens.init_i2c()\nhuskylens.init_mode(protocolAlgorithm.OBJECTCLASSIFICATION)\n# === 2. อ่านค่าและแสดงผลบนบอร์ดตัวเอง ===\n\ndef on_forever():\n    huskylens.request()\n    \n    # 1. ตรวจพบใบไม้สุขภาพดี (ID 1) -> แสดงรูปหัวใจและปิดพัดลม\n    if huskylens.is_appear(1, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.HEART)\n        pins.digital_write_pin(DigitalPin.P15, 0)\n        \n    # 2. ตรวจพบใบไม้มีปัญหา (ID 2) -> แสดงรูปหัวกะโหลกและปิดพัดลม\n    elif huskylens.is_appear(2, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.SKULL)\n        pins.digital_write_pin(DigitalPin.P15, 0)\n        \n    # 3. ตรวจพบแมลงศัตรูพืช (ID 3 = แมลงปอ, ID 4 = ผีเสื้อ, ID 5 = ตั๊กแตน)\n    elif huskylens.is_appear(3, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(4, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(5, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        \n        # --- เริ่มขั้นตอนการตรวจสอบความถูกต้องเชิงเวลา (Insect Verification - 5 วินาที) ---\n        is_real_pest = True\n        for i in range(5):  # วนลูปตรวจสอบซ้ำ 5 ครั้ง ครั้งละ 1 วินาที (รวมเป็นเวลา 5 วินาที)\n            basic.pause(1000)\n            huskylens.request()\n            # ถ้าในระหว่างช่วงเวลา 5 วินาทีนี้ แมลงหายไปจากเฟรมภาพแม้แต่วินาทีเดียว ให้ถือเป็นสัญญาณหลอก (False Alarm)\n            if not (huskylens.is_appear(3, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n                    huskylens.is_appear(4, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n                    huskylens.is_appear(5, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK)):\n                is_real_pest = False\n                break  # หลุดออกจากลูปตรวจเช็คทันที\n        \n        # หากผ่านการตรวจซ้ำแล้วพบว่าเป็นแมลงตัวเดิมค้างอยู่อย่างต่อเนื่องจนครบ 5 วินาทีจริง\n        if is_real_pest:\n            basic.show_icon(IconNames.ANGRY)\n            # จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์พัดลม P15\n            pins.analog_write_pin(AnalogPin.P15, 1023)\n            # เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที\n            basic.pause(3000)\n            # ปิดมอเตอร์พัดลมเมื่อทำงานเสร็จสิ้น\n            pins.analog_write_pin(AnalogPin.P15, 0)\n        else:\n            # หากเป็นเพียงภาพสแกนแวบผ่านเข้ามาแล้วหายไป ให้เคลียร์จอและปิดพัดลม\n            basic.clear_screen()\n            pins.digital_write_pin(DigitalPin.P15, 0)\n        \n    # 4. กรณีสแกนไม่พบเป้าหมายที่เรียนรู้ใดๆ เลย\n    else:\n        basic.clear_screen()\n        pins.digital_write_pin(DigitalPin.P15, 0)\n        \n    basic.pause(100)\n\nbasic.forever(on_forever)","pxt.json":"{\n    \"name\": \"09 Husky Lens & Fan\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"Huskylens\": \"github:dfrobot/pxt-dfrobot_huskylens#v2.0.7\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1779583836664,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"!3E(x*=ZeO{w:=5dcY-f\">is_real_pest</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">1000</field></shadow></value><next><block type=\"device_clear_display\"><next><block type=\"huskylens_initI2c\"><comment pinned=\"false\" h=\"80\" w=\"160\">เชื่อมต่อกล้อง I2C และตั้งโหมดจำแนกวัตถุ (Object Classification)</comment><next><block type=\"huskylens_initMode\"><field name=\"mode\">protocolAlgorithm.OBJECTCLASSIFICATION</field></block></next></block></next></block></next></block></statement></block><block type=\"device_