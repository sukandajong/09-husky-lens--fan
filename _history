{"entries":[{"timestamp":1779362981066,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":185,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":1611,"diffs":[[1,"\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":125,"length1":94,"diffs":[[1,"        \"microphone\": \"*\"\n"]]},{"start1":215,"length1":39,"diffs":[[1,"        \"README.md\"\n"]]},{"start1":242,"length1":31,"diffs":[[1,"    \"additionalFilePaths\": []\n"]]}]},{"type":"added","filename":"main.py","value":"basic.pause(1000)\nbasic.clear_screen()\n# เชื่อมต่อกล้อง I2C และตั้งโหมดจดจำสี\nhuskylens.init_i2c()\nhuskylens.init_mode(protocolAlgorithm.ALGORITHM_COLOR_RECOGNITION)\n# === 2. อ่านค่าและแสดงผลบนบอร์ดตัวเอง ===\n\ndef on_forever():\n    huskylens.request()\n    \n    # 1. ตรวจพบใบไม้สุขภาพดี (ID 1) -> แสดงรูปหัวใจและปิดพัดลม\n    if huskylens.is_appear(1, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.HEART)\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    # 2. ตรวจพบใบไม้มีปัญหา (ID 2) -> แสดงรูปหัวกะโหลกและปิดพัดลม\n    elif huskylens.is_appear(2, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.SKULL)\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    # 3. ตรวจพบแมลง (ID 3 = แมลงปอ, ID 4 = ผีเสื้อ, ID 5 = ตั๊กแตน) -> แสดงหน้าโกรธและเป่าพัดลมแรงสูงสุดไล่แมลง\n    elif huskylens.is_appear(3, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(4, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(5, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        \n        basic.show_icon(IconNames.ANGRY)\n        # จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์ใบพัดสีแดง\n        pins.analog_write_pin(AnalogPin.P16, 1023)\n        # เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที\n        basic.pause(3000)\n        # ปิดมอเตอร์พัดลมเมื่อทำงานเสร็จสิ้น\n        pins.analog_write_pin(AnalogPin.P16, 0)\n        \n    # 4. กรณีสแกนไม่พบเป้าหมายสีที่เรียนรู้ใดๆ เลย\n    else:\n        basic.clear_screen()\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    basic.pause(100)\n\nbasic.forever(on_forever)"}]},{"timestamp":1779363097721,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":9621,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":38,"length1":68,"diffs":[[1,"//  เชื่อมต่อกล้อง I2C และตั้งโหมดจดจำสี\n"]]},{"start1":99,"length1":246,"diffs":[[1,"huskylens.initMode(protocolAlgorithm.ALGORITHM_COLOR_RECOGNITION)\n//  === 2. อ่านค่าและแสดงผลบนบอร์ดตัวเอง ===\nbasic.forever(function on_forever() {\n    huskylens.request()\n    //  1. ตรวจพบใบไม้สุขภาพดี (ID 1) -> แสดงรูปหัวใจและปิดพัดลม\n"]]},{"start1":454,"length1":47,"diffs":[[1,"        pins.digitalWritePin(DigitalPin.P16, 0)\n"]]},{"start1":586,"length1":71,"diffs":[[1,"        //  2. ตรวจพบใบไม้มีปัญหา (ID 2) -> แสดงรูปหัวกะโหลกและปิดพัดลม\n"]]},{"start1":698,"length1":48,"diffs":[[1,"        pins.digitalWritePin(DigitalPin.P16, 0)\n"]]},{"start1":968,"length1":1543,"diffs":[[1,"        //  3. ตรวจพบแมลง (ID 3 = แมลงปอ, ID 4 = ผีเสื้อ, ID 5 = ตั๊กแตน) -> แสดงหน้าโกรธและเป่าพัดลมแรงสูงสุดไล่แมลง\n        basic.showIcon(IconNames.Angry)\n        //  จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์ใบพัดสีแดง\n        pins.analogWritePin(AnalogPin.P16, 1023)\n        //  เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที\n        basic.pause(3000)\n        //  ปิดมอเตอร์พัดลมเมื่อทำงานเสร็จสิ้น\n        pins.analogWrit