shadow></value></block></next></block></statement><value name=\"IF2\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_operation\"><field name=\"OP\">OR</field><value name=\"A\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_operation\"><field name=\"OP\">OR</field><value name=\"A\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"huskylens_isAppear\"><field name=\"Ht\">HUSKYLENSResultType_t.HUSKYLENSResultBlock</field><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">3</field></shadow></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"huskylens_isAppear\"><field name=\"Ht\">HUSKYLENSResultType_t.HUSKYLENSResultBlock</field><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">4</field></shadow></value></block></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"huskylens_isAppear\"><field name=\"Ht\">HUSKYLENSResultType_t.HUSKYLENSResultBlock</field><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">5</field></shadow></value></block></value></block></value><statement name=\"DO2\"><block type=\"basic_show_icon\"><field name=\"i\">IconNames.Angry</field><comment pinned=\"false\" h=\"80\" w=\"160\">3. ตรวจพบแมลงศัตรูพืช (ID 3 = แมลงปอ, ID 4 = ผีเสื้อ, ID 5 = ตั๊กแตน) -&gt; แสดงหน้าโกรธและเป่าพัดลมแรงสูงสุดไล่แมลง</comment><next><block type=\"device_set_analog_pin\"><comment pinned=\"false\" h=\"80\" w=\"160\">จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์ใบพัดสีแดง</comment><value name=\"name\"><shadow type=\"analog_pin_shadow\"><field name=\"pin\">AnalogPin.P15</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1023\" precision=\"0\"></mutation><field name=\"SLIDER\">1023</field></shadow></value><next><block type=\"device_pause\"><comment pinned=\"false\" h=\"80\" w=\"160\">เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที</comment><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">3000</field></shadow></value><next><block type=\"device_set_analog_pin\"><comment pinned=\"false\" h=\"80\" w=\"160\">ปิดมอเตอร์พัดลมเมื่อทำงานเสร็จสิ้น</comment><value name=\"name\"><shadow type=\"analog_pin_shadow\"><field name=\"pin\">AnalogPin.P15</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1023\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value></block></next></block></next></block></next></block></statement><statement name=\"ELSE\"><block type=\"device_clear_display\"><comment pinned=\"false\" h=\"80\" w=\"160\">4. กรณีสแกนไม่พบเป้าหมายที่เรียนรู้ใดๆ เลย</comment><next><block type=\"device_set_digital_pin\"><value name=\"name\"><shadow type=\"digital_pin_shadow\"><field name=\"pin\">DigitalPin.P15</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow></value></block></next></block></statement><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">100</field></shadow></value></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":"","main.py":"basic.pause(1000)\nbasic.clear_screen()\n# เชื่อมต่อกล้อง I2C และตั้งโหมดจำแนกวัตถุ (Object Classification)\nhuskylens.init_i2c()\nhuskylens.init_mode(protocolAlgorithm.OBJECTCLASSIFICATION)\n# === 2. อ่านค่าและแสดงผลบนบอร์ดตัวเอง ===\n\ndef on_forever():\n    huskylens.request()\n    \n    # 1. ตรวจพบใบไม้สุขภาพดี (ID 1) -> แสดงรูปหัวใจและปิดพัดลม\n    if huskylens.is_appear(1, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.HEART)\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    # 2. ตรวจพบใบไม้มีปัญหา (ID 2) -> แสดงรูปหัวกะโหลกและปิดพัดลม\n    elif huskylens.is_appear(2, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        basic.show_icon(IconNames.SKULL)\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    # 3. ตรวจพบแมลงศัตรูพืช (ID 3 = แมลงปอ, ID 4 = ผีเสื้อ, ID 5 = ตั๊กแตน) -> แสดงหน้าโกรธและเป่าพัดลมแรงสูงสุดไล่แมลง\n    elif huskylens.is_appear(3, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(4, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK) or \\\n         huskylens.is_appear(5, HUSKYLENSResultType_t.HUSKYLENS_RESULT_BLOCK):\n        \n        basic.show_icon(IconNames.ANGRY)\n        # จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์ใบพัดสีแดง\n        pins.analog_write_pin(AnalogPin.P16, 1023)\n        # เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที\n        basic.pause(3000)\n        # ปิดมอเตอร์พัดลมเมื่อทำงานเสร็จสิ้น\n        pins.analog_write_pin(AnalogPin.P16, 0)\n        \n    # 4. กรณีสแกนไม่พบเป้าหมายที่เรียนรู้ใดๆ เลย\n    else:\n        basic.clear_screen()\n        pins.digital_write_pin(DigitalPin.P16, 0)\n        \n    basic.pause(100)\n\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"09 Husky Lens & Fan\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"Huskylens\": \"github:dfrobot/pxt-dfrobot_huskylens#v2.0.7\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1779575673380,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"!3E(x*=ZeO{w:=5dcY-f\">is_real_pest</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"device_pause\"><value name=\"pause\"><shad