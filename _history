k</field><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">4</field></shadow></value></block></value></block></value><value name=\"B\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"huskylens_isAppear\"><field name=\"Ht\">HUSKYLENSResultType_t.HUSKYLENSResultBlock</field><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">5</field></shadow></value></block></value></block></value></block></value><statement name=\"DO0\"><block type=\"variables_set\"><field name=\"VAR\" id=\"!3E(x*=ZeO{w:=5dcY-f\">is_real_pest</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"logic_boolean\"><field name=\"BOOL\">FALSE</field></block></value><next><block type=\"break_keyword\"></block></next></block></statement></block></next></block></next></block></statement><next><block type=\"controls_if\"><mutation else=\"1\"></mutation><comment pinned=\"false\" h=\"80\" w=\"160\">หลุดออกจากลูปตรวจเช็คทันที\nหากผ่านการตรวจซ้ำแล้วพบว่าเป็นแมลงตัวเดิมค้างอยู่อย่างต่อเนื่องจนครบ 5 วินาทีจริง</comment><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"!3E(x*=ZeO{w:=5dcY-f\">is_real_pest</field></block></value><statement name=\"DO0\"><block type=\"basic_show_icon\"><field name=\"i\">IconNames.Angry</field><next><block type=\"device_set_analog_pin\"><comment pinned=\"false\" h=\"80\" w=\"160\">จ่ายสัญญาณ Analog ความแรง 100% (ค่า 1023) ไปสั่งหมุนมอเตอร์พัดลม P15</comment><value name=\"name\"><shadow type=\"analog_pin_shadow\"><field name=\"pin\">AnalogPin.P15</field></shadow></value><value name=\"value\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"1023\" precision=\"0\"></mutation><field name=\"SLIDER\">1023</field></shadow></value><next><block type=\"device_pause\"><comment pinned=\"false\" h=\"80\" w=\"160\">เปิดเป่าลมไล่แมลงค้างไว้เป็นเวลา 3 วินาที</comment>